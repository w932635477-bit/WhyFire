# ============================================================================
# WhyFire - AI 方言 Rap 生成器
# ============================================================================

# Anthropic Claude API - 歌词生成
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# SunoAPI - Rap 音乐生成（Add Vocals 模式）
SUNOAPI_API_KEY=your_sunoapi_api_key_here

# ============================================================================
# 核心服务
# ============================================================================

# Seed-VC 零样本声音克隆 (Modal GPU)
# 后端: mock（本地测试）| modal（生产环境）
SEEDVC_BACKEND=mock
SEEDVC_ENDPOINT=

# Modal Serverless GPU
MODAL_WEB_ENDPOINT_URL=
MODAL_API_TOKEN=

# DashScope (阿里云) - CosyVoice 声音复刻注册
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 阿里云 OSS - 音频文件存储
OSS_ACCESS_KEY_ID=your_oss_access_key_id_here
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret_here
OSS_BUCKET=your_oss_bucket_name_here
OSS_REGION=oss-cn-beijing

# ============================================================================
# 辅助服务
# ============================================================================

# Serper API - 热点搜索（可选，用于歌词时效性数据）
SERPER_API_KEY=your_serper_api_key_here

# Supabase - 用户认证（可选）
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 应用配置
NEXT_PUBLIC_APP_URL=http://localhost:3000
