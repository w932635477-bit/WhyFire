# Claude API (Anthropic 或国内代理)
# 官方 API: https://console.anthropic.com/
# 国内代理示例: https://api.evolink.ai
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 可选：自定义 API 端点（用于国内代理）
# 国内代理示例：https://api.evolink.ai
ANTHROPIC_BASE_URL=

# YouTube Data API v3
# 获取地址: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Apify (TikTok 数据源)
# 获取地址: https://console.apify.com/
APIFY_TOKEN=your_apify_token_here
