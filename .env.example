# Anthropic Claude API - 用于生成 Rap 歌词（通过 EvoLink 代理）
EVOLINK_API_KEY=your_evolink_api_key_here

# 智谱AI GLM-5 - 新一代旗舰基座模型，面向 Agentic Engineering 打造
# 获取 API Key: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# ============================================================================
# 方言 Rap 生成系统 - 核心服务
# ============================================================================

# DashScope (阿里云百炼) - CosyVoice 3 方言 TTS
# 支持的方言: 普通话、粤语、四川话、东北话、山东话、上海话、河南话、湖南话
# 获取 API Key: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 可选: 设置为 'international' 使用新加坡节点
# DASHSCOPE_REGION=international

# 阿里云 OSS - 声音克隆音频存储（声音复刻需要公网可访问的音频 URL）
# 获取 AccessKey: https://ram.console.aliyun.com/manage/ak
# 创建 Bucket: https://oss.console.aliyun.com/
OSS_ACCESS_KEY_ID=your_oss_access_key_id_here
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret_here
OSS_BUCKET=your_oss_bucket_name_here
OSS_REGION=oss-cn-beijing

# GPT-SoVITS - 声音克隆服务（可选，自部署）
# 用于克隆用户声音，让用户用自己的声音唱 Rap
# GitHub: https://github.com/RVC-Boss/GPT-SoVITS
# GPT_SOVITS_API_URL=http://your-gpt-sovits-server:8000
# GPT_SOVITS_API_KEY=your_api_key_if_needed

# ============================================================================
# Suno API - AI 音乐生成（通过 Evolink 代理）
# ============================================================================

# Suno API - 用于生成高质量 Rap 音乐
# 方案：Suno 生成 Rap → RVC/GPT-SoVITS 替换音色 → 用户克隆声音的 Rap
# 获取 API Key: https://docs.evolink.ai
SUNO_API_KEY=your_suno_api_key_here

# 可选: 自定义 API 地址（默认使用 Evolink）
# SUNO_API_URL=https://api.evolink.ai

# ============================================================================
# 自托管服务（GPU 服务器）
# ============================================================================

# RVC 服务 - 音色替换
# 部署文档: docs/self-hosted-deployment.md
RVC_API_URL=http://localhost:8001

# Demucs 服务 - 人声分离
# 部署文档: docs/self-hosted-deployment.md
DEMUCS_API_URL=http://localhost:8002

# FFmpeg 混音服务（可选，默认使用本地 FFmpeg）
# FFMPEG_API_URL=http://localhost:8003

# ============================================================================
# 已废弃的服务（保留用于向后兼容，建议移除）
# ============================================================================

# [已废弃] MiniMax API - 已被 CosyVoice + GPT-SoVITS 替代
# MINIMAX_API_KEY=your_minimax_api_key_here
# MINIMAX_GROUP_ID=your_minimax_group_id_here

# [已废弃] Fish Audio API - 已被 CosyVoice + GPT-SoVITS 替代
# FISH_AUDIO_API_KEY=your_fish_audio_api_key_here

# ============================================================================
# 辅助服务
# ============================================================================

# Serper API - 热点搜索（可选）
# 获取 API Key: https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# Supabase - 数据库和认证
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# WeChat Pay - 微信支付
WECHAT_APP_ID=your_wechat_app_id_here
WECHAT_MCH_ID=your_wechat_mch_id_here
WECHAT_PAY_API_KEY=your_wechat_pay_api_key_here
WECHAT_PAY_API_V3_KEY=your_wechat_pay_api_v3_key_here
WECHAT_PAY_SERIAL_NO=your_wechat_pay_serial_no_here
WECHAT_PAY_PRIVATE_KEY=your_wechat_pay_private_key_here
WECHAT_PAY_NOTIFY_URL=https://yourdomain.com/api/payments/callback
