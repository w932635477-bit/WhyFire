# 方言Rap生成系统 - 环境变量配置示例
# 复制此文件为 .env.local 并填写实际值

# ==============================================
# 基础配置
# ==============================================

# 应用环境 (development | production)
NODE_ENV=development

# 调试模式 - 显示验证码（仅开发环境使用）
VERIFICATION_DEBUG_MODE=true

# ==============================================
# 缓存配置
# ==============================================

# 缓存提供者 (redis | memory)
CACHE_PROVIDER=memory

# Redis URL（如果使用 Redis）
# REDIS_URL=redis://localhost:6379

# ==============================================
# 加密配置（生产环境必须设置！）
# ==============================================

# 加密密钥 - 32字节的hex字符串
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ==============================================
# 微信登录配置（可选）
# ==============================================

WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=http://localhost:3000/api/auth/wechat/callback

# ==============================================
# CosyVoice TTS 配置
# ==============================================

ALIBABA_CLOUD_API_KEY=
DASHSCOPE_API_KEY=
COSYVOICE_MODEL=cosyvoice-v1

# ==============================================
# 功能开关
# ==============================================

USE_NEW_VOICE_SYSTEM=true
USE_RHYTHM_ADAPTOR=true
USE_COSYVOICE_TTS=true
USE_GUEST_MODE=true
