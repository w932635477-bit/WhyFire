{
  "name": "whyfire",
  "version": "2.2.0",
  "private": true,
  "description": "AI Rap 视频一键生成器 - 输入信息，一键生成创意短视频",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "USE_MOCK_SERVICES=true vitest run tests/e2e",
    "test:e2e:real": "FORCE_REAL_SERVICES=true E2E_REAL=true vitest run tests/e2e --single-thread",
    "modal:setup": "npx tsx scripts/setup-modal.ts",
    "modal:verify": "npx tsx scripts/verify-modal-api.ts",
    "modal:deploy": "python3 -m modal deploy modal/seed_vc_mock.py",
    "modal:serve": "python3 -m modal serve modal/seed_vc_mock.py",
    "modal:logs": "python3 -m modal app logs seed-vc-mock",
    "modal:info": "python3 -m modal app show seed-vc-mock",
    "modal:token": "npx tsx scripts/configure-modal-token.ts",
    "seedvc:test": "npx tsx scripts/test-seedvc-mock.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "@types/ws": "^8.18.1",
    "ali-oss": "^6.23.0",
    "bufferutil": "4.0.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "global-agent": "^4.1.3",
    "https-proxy-agent": "^8.0.0",
    "lucide-react": "^0.577.0",
    "music-metadata": "^11.12.3",
    "next": "^15.2.0",
    "pitchfinder": "^2.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0",
    "undici": "^7.24.6",
    "web-audio-beat-detector": "^8.2.36",
    "wechatpay-node-v3": "^2.2.1",
    "ws": "8.18.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/ali-oss": "^6.23.3",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "autoprefixer": "^10.4.0",
    "dotenv": "^17.3.1",
    "jsdom": "^29.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}
